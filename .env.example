EXPO_PUBLIC_NUTRITION_API_URL=http://localhost:3000/v1
EXPO_PUBLIC_TRAINING_API_URL=http://localhost:8010/api
EXPO_PUBLIC_TURNSTILE_BRIDGE_URL=https://app.fitpilot.fit/turnstile/mobile
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=
EXPO_ANDROID_GOOGLE_SERVICES_FILE=./google-services.json

# Si corres la app en un dispositivo fisico, reemplaza localhost por la IP LAN del host.
# Ejemplo:
# EXPO_PUBLIC_NUTRITION_API_URL=http://192.168.1.20:3000/v1
# EXPO_PUBLIC_TRAINING_API_URL=http://192.168.1.20:8010/api
#
# Para EAS Build, sube el archivo de Firebase como variable tipo "file"
# con el nombre GOOGLE_SERVICES_JSON.
